---
---
<section id="kontakt" class="py-24 lg:py-32">
  <div class="wrap">
    <div class="relative overflow-hidden rounded-3xl bg-ink text-white px-10 py-20 lg:py-28 text-center">
      <!-- Background pattern -->
      <div class="absolute inset-0 pointer-events-none opacity-30"
           style="background: radial-gradient(ellipse 50% 80% at 50% 0%, rgba(245,180,0,0.30) 0%, transparent 60%);"></div>
      <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-white/20 to-transparent"></div>

      <div class="relative max-w-[720px] mx-auto">
        <h2 class="mb-6">
          <span class="block font-extrabold text-white leading-[0.95] tracking-tighter" style="font-size: clamp(36px, 5vw, 64px);">
            Klar til å sette
          </span>
          <span class="block h-display text-yellow" style="font-size: clamp(36px, 5vw, 64px); line-height: 1;">
            kunnskap i system?
          </span>
        </h2>
        <p class="text-lg text-white/70 mb-10 leading-[1.65] max-w-[520px] mx-auto">
          Kontakt oss for en uforpliktende demo av hvordan BYGG-KON.ai
          kan akselerere hverdagen til dine ansatte.
        </p>
        <div class="flex flex-wrap gap-3 justify-center">
          <a href="mailto:oat@byggkon.no" class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full bg-yellow text-ink font-semibold text-sm hover:bg-[#ffd34d] transition-colors">
            Book demo →
          </a>
          <a href="tel:+4751974400" class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full border border-white/25 text-white font-semibold text-sm hover:bg-white/10 hover:border-white transition-colors">
            +47 51 97 44 00
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
