---
const vendors = [
  'Claude',
  'MCP',
  'Vektordatabaser',
  'Microsoft 365',
  'Tripletex',
  'Kartverket',
  'OpenAI'
];
---
<section class="py-12 border-y border-line bg-cream/40">
  <div class="wrap">
    <div class="text-center mb-6">
      <span class="text-xs font-semibold uppercase tracking-[0.22em] text-ink-4">Bygget på</span>
    </div>
    <div class="flex flex-wrap items-center justify-center gap-x-10 gap-y-4">
      {vendors.map(v => (
        <span class="text-[15px] font-semibold text-ink-3 hover:text-ink transition-colors">{v}</span>
      ))}
    </div>
  </div>
</section>
