---
type Step = { icon: string; name: string; sub: string; agentColor?: string };
type Case = {
  category: string; title: string; description: string;
  output: string; pages: string; time: string; color: string;
  flow: Step[];
};

const cases: Case[] = [
  {
    category: 'Byggesak', title: 'Søknad om dispensasjon',
    description: 'Komplett dispensasjonssøknad med kildehenvisninger til PBL §19-2 og TEK17 §13-7.',
    output: 'Dispensasjonssøknad.pdf', pages: '4 sider', time: '38 sek', color: '#c8102e',
    flow: [
      { icon: '💬', name: 'Forespørsel', sub: '"Lag dispensasjonssøknad for prosjekt Solås"' },
      { icon: '📚', name: 'Loki + Nova', sub: 'Interne søknader + PBL §19-2 + TEK17 §13-7', agentColor: '#c8102e' },
      { icon: '🗺️', name: 'Hilde',       sub: 'Gnr/bnr og eier verifisert', agentColor: '#0a6cf0' },
      { icon: '⚙️', name: 'Claude',      sub: 'Komponerer søknad i BYGG-KON-mal' },
      { icon: '📄', name: 'Levert',      sub: 'PDF sendt til byggherre og kommune' }
    ]
  },
  {
    category: 'Uavhengig kontroll', title: 'Sjekkliste for UAK',
    description: 'Kontrollpunkter knyttet mot TEK17 §13, NS 3420-T og BVN 31.110.',
    output: 'UAK-sjekkliste-Vatrom.pdf', pages: '6 sider', time: '22 sek', color: '#f5b400',
    flow: [
      { icon: '💬', name: 'Forespørsel', sub: '"Lag UAK-sjekkliste for våtrom"' },
      { icon: '📚', name: 'Loki',         sub: 'BYGG-KONs UAK-maler for våtrom', agentColor: '#c8102e' },
      { icon: '📋', name: 'Nova',         sub: 'TEK17 §13, NS 3420-T, BVN 31.110', agentColor: '#f5b400' },
      { icon: '⚙️', name: 'Claude',       sub: 'Bygger kontrollpunkter med kilder' },
      { icon: '✅', name: 'Klar',         sub: 'PDF distribuert til UAK-foretak' }
    ]
  },
  {
    category: 'Fagprosjektering', title: 'KS-plan betong, enebolig',
    description: 'Kvalitetssikringsplan etter NS 3473 og Eurokode 2. 24 kontrollpunkter.',
    output: 'KS-plan-Betong-4118.pdf', pages: '12 sider', time: '51 sek', color: '#0a6cf0',
    flow: [
      { icon: '💬', name: 'Forespørsel',     sub: '"Lag KS-plan for betongprosjektering"' },
      { icon: '📚', name: 'Loki + Nova',     sub: 'Tidligere enebolig-KS + NS 3473', agentColor: '#f5b400' },
      { icon: '🗺️', name: 'Hilde + Tripletex', sub: 'Tomt + prosjektnr', agentColor: '#7a3fc8' },
      { icon: '⚙️', name: 'Claude',           sub: 'Knytter risikopunkter til Eurokode 2' },
      { icon: '🧱', name: 'Klar',             sub: 'KS-plan klar til kvalitetsleder' }
    ]
  },
  {
    category: 'Befaring', title: 'Befaringsrapport stål',
    description: 'Funn klassifisert etter alvorlighet med tiltak per knutepunkt.',
    output: 'Befaringsrapport-stal-4072.pdf', pages: '8 sider', time: '33 sek', color: '#7a3fc8',
    flow: [
      { icon: '💬', name: 'Forespørsel',  sub: '"Skriv befaringsrapport — knutepunkt 4072"' },
      { icon: '📧', name: 'Epostagent',  sub: 'Henter befaringsnotater fra e-postkjede', agentColor: '#ff6b35' },
      { icon: '📚', name: 'Loki + Nova', sub: 'Tidligere befaringer + NS-EN 1090/1993', agentColor: '#c8102e' },
      { icon: '⚙️', name: 'Claude',      sub: 'Klassifiserer avvik og anbefaler tiltak' },
      { icon: '🔧', name: 'Levert',      sub: 'Rapport sendt til byggherre + utførende' }
    ]
  }
];
---
<section id="leveranser" class="py-28 lg:py-36 relative overflow-hidden">

  <!-- Background orbs for ambient motion -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="orb" style="width:400px; height:400px; background:#0a6cf0; top:100px; left:-150px; opacity:0.10; filter:blur(100px); animation: drift-3 28s ease-in-out infinite;"></div>
    <div class="orb" style="width:500px; height:500px; background:#f5b400; bottom:-200px; right:-100px; opacity:0.12; filter:blur(120px); animation: drift-1 24s ease-in-out infinite;"></div>
  </div>

  <div class="wrap">

    <div class="max-w-[760px] mb-16 lg:mb-20 reveal">
      <div class="eyebrow mb-5">
        <span class="w-1.5 h-1.5 rounded-full bg-loki"></span>
        Leveranser
      </div>
      <h2 class="h2 mb-6">
        Ferdige dokumenter,
        <span class="h-display block">på sekunder.</span>
      </h2>
      <p class="lede max-w-[600px]">
        Faktiske dokumenter som BYGG-KON.ai genererer på forespørsel. Hver leveranse
        viser hele prosessen — fra første prompt til ferdig levert PDF.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5 lg:gap-7 reveal">
      {cases.map((c, ci) => (
        <article class="card overflow-hidden">
          <!-- Header -->
          <div class="p-7 lg:p-8 pb-0">
            <div class="flex items-center gap-2 mb-4">
              <span class="inline-block w-1.5 h-1.5 rounded-full" style={`background:${c.color}`}></span>
              <span class="text-[11px] font-semibold uppercase tracking-[0.16em] text-ink-4">{c.category}</span>
            </div>
            <h3 class="text-2xl font-extrabold text-ink leading-tight mb-3 tracking-tight">{c.title}</h3>
            <p class="text-[15px] text-ink-3 leading-[1.65] mb-5">{c.description}</p>
          </div>

          <!-- Vertical flow -->
          <div class="px-7 lg:px-8 py-6 bg-cream/70 border-y border-line" style={`--c:${c.color};`}>
            <div class="text-[10px] font-bold uppercase tracking-[0.2em] text-ink-4 mb-5">// Prosess</div>

            <div class="ek-flow relative">
              <div class="ek-rail"></div>
              <div class="ek-traveler" style={`--c:${c.color}; --delay:${ci * 0.3}s;`}></div>

              {c.flow.map((step, i) => (
                <div class="ek-step" style={`--delay:${(ci * 0.3 + i * 1.0)}s; --c:${step.agentColor || c.color};`}>
                  <div class="ek-dot"></div>
                  <div class="ek-icon">{step.icon}</div>
                  <div class="ek-text">
                    <div class="ek-name">{step.name}</div>
                    <div class="ek-sub">{step.sub}</div>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- Footer meta -->
          <div class="p-7 lg:p-8 pt-5 flex items-center gap-x-5 gap-y-2 flex-wrap">
            <div class="flex items-center gap-2 text-sm text-ink-4">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
              </svg>
              <span class="font-mono text-xs">{c.output}</span>
            </div>
            <div class="text-sm text-ink-4">{c.pages}</div>
            <div class="flex items-center gap-2 text-sm ml-auto">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-ink-4">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
              <span class="font-bold text-ink">{c.time}</span>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .ek-flow { position: relative; padding-left: 4px; }
  .ek-rail {
    position: absolute; left: 11px; top: 12px; bottom: 12px; width: 2px;
    background: rgba(10, 13, 18, 0.08); border-radius: 2px;
  }
  .ek-traveler {
    position: absolute; left: 7px; top: 0;
    width: 10px; height: 10px; border-radius: 50%;
    background: var(--c);
    box-shadow: 0 0 0 4px rgba(10, 13, 18, 0.05);
    opacity: 0; pointer-events: none;
    animation: ek-travel 6s linear infinite;
    animation-delay: var(--delay, 0s);
  }
  @keyframes ek-travel {
    0%       { opacity: 0; transform: translateY(0); }
    8%       { opacity: 1; }
    92%      { opacity: 1; }
    100%     { opacity: 0; transform: translateY(290px); }
  }
  .ek-step {
    display: grid; grid-template-columns: 24px 28px 1fr;
    align-items: center; gap: 12px; min-height: 58px;
    position: relative;
  }
  .ek-dot {
    width: 14px; height: 14px; border-radius: 50%;
    background: #ffffff; border: 2px solid var(--c);
    margin-left: 2px; z-index: 1;
  }
  .ek-step::before {
    content: ''; position: absolute; left: 0;
    width: 14px; height: 14px; border-radius: 50%;
    background: var(--c); opacity: 0; margin-left: 7px;
    animation: ek-dot-fill 6s linear infinite;
    animation-delay: var(--delay, 0s); pointer-events: none;
  }
  @keyframes ek-dot-fill {
    0%, 14%   { opacity: 0; transform: scale(0.6); }
    15%, 100% { opacity: 1; transform: scale(1); }
  }
  .ek-icon { font-size: 18px; line-height: 1; text-align: center; }
  .ek-name { font-size: 13px; font-weight: 700; color: #0a0d12; line-height: 1.3; }
  .ek-sub  { font-size: 11.5px; color: #6b7280; line-height: 1.4; margin-top: 1px; }

  @media (prefers-reduced-motion: reduce) {
    .ek-traveler, .ek-step::before { animation: none !important; }
    .ek-step::before { opacity: 1; }
  }
</style>
