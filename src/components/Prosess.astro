---
const konsepter = [
  {
    title: 'Claude',
    sub: 'Språkmodellen som resonnerer',
    icon: `<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 2a4 4 0 0 0-4 4v1H6a4 4 0 0 0 0 8h.5"/><path d="M12 22a4 4 0 0 0 4-4v-1h2a4 4 0 0 0 0-8H17.5"/><path d="M12 2a4 4 0 0 1 4 4v1h2a4 4 0 0 1 0 8h-.5"/><path d="M12 22a4 4 0 0 1-4-4v-1H6a4 4 0 0 1 0-8h.5"/></svg>`,
    body: 'Claude er en stor språkmodell utviklet av Anthropic. Den forstår norsk og faglige byggtekniske begreper, og resonnerer over kompliserte oppgaver fra TEK17 og NS-standarder.'
  },
  {
    title: 'MCP',
    sub: 'Model Context Protocol',
    icon: `<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M9 12h6"/><path d="M9 12v-5a3 3 0 0 1 6 0v5"/><path d="M9 12v5a3 3 0 0 0 6 0v-5"/><circle cx="9" cy="12" r="2"/><circle cx="15" cy="12" r="2"/></svg>`,
    body: 'En åpen standard som lar språkmodeller koble seg til eksterne datakilder og verktøy. Hver agent eksponerer en MCP-server som Claude kan kalle direkte.'
  },
  {
    title: 'Pinecone',
    sub: 'Vektordatabasen',
    icon: `<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v6c0 1.7 4 3 9 3s9-1.3 9-3V5"/><path d="M3 11v6c0 1.7 4 3 9 3s9-1.3 9-3v-6"/></svg>`,
    body: 'Dokumenter lagres som matematiske embeddings — slik kan systemet finne meningsmessig nærmeste innhold, ikke bare tekstmatch. Hver fil blir søkbar på sekunder.'
  },
  {
    title: 'RAG',
    sub: 'Retrieval-Augmented Generation',
    icon: `<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 12h10"/><path d="M10 6l-6 6 6 6"/><path d="M20 18V6"/><circle cx="20" cy="12" r="2.5"/></svg>`,
    body: 'Modellen henter relevant kontekst fra vektordatabasen før den svarer. Hvert svar er forankret i BYGG-KONs kunnskap og kilder — med sporbare referanser.'
  }
];
---
<section id="stack" class="py-24 lg:py-32 bg-cream">
  <div class="wrap">

    <div class="max-w-[760px] mb-14 lg:mb-20">
      <div class="eyebrow mb-5">
        <span class="w-1.5 h-1.5 rounded-full bg-loki"></span>
        Stack
      </div>
      <h2 class="h2 mb-6">
        Teknologien bak,
        <span class="h-display block">forklart enkelt.</span>
      </h2>
      <p class="lede max-w-[600px]">
        Plattformen bygger på fire byggesteiner. Sammen utgjør de en kjede der
        ansattes spørsmål ender opp som ferdig dokumentasjon.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5 lg:gap-6">
      {konsepter.map(k => (
        <article class="card p-8 lg:p-9">
          <div class="w-12 h-12 rounded-xl bg-ink/[0.04] text-ink flex items-center justify-center mb-8">
            <Fragment set:html={k.icon} />
          </div>
          <h3 class="text-xl font-extrabold text-ink leading-tight mb-1.5 tracking-tight">{k.title}</h3>
          <div class="text-sm text-ink-4 mb-5">{k.sub}</div>
          <p class="text-[14.5px] text-ink-3 leading-[1.65]">{k.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>
